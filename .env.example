# Groq API Keys (Get them from https://console.groq.com/keys)
# You can provide up to 4 keys for load balancing and rate-limit resilience.
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# Flask Configuration
FLASK_SECRET=replace-this-with-a-long-random-string
DEBUG=false
LOG_LEVEL=INFO
PORT=10000

# Async Mode for SocketIO (gevent is required for production/Render)
ASYNC_MODE=gevent